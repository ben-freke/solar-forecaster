# Required: solar installation parameters
SF_LAT=51.5
SF_LON=-0.1
SF_DECLINATION=35
SF_AZIMUTH=0
SF_KWP=5.0

# Optional: forecast.solar API key (raises rate limit and allows higher resolution)
# SF_API_KEY=

# Optional: inverter cap in kW (0 = unlimited)
SF_INVERTER_KW=0

# Optional: forecast shaping
SF_LIMIT=2           # days to forecast (1-8)
SF_RESOLUTION=60     # data resolution in minutes (15, 30, 60)
# SF_DAMPING=0.5
# SF_DAMPING_MORNING=0.25
# SF_DAMPING_EVENING=0.75

# Horizon file path (mounted into the container)
SF_HORIZON_FILE=/etc/solar-forecaster/horizon.txt

# Cron expression (6 fields, seconds supported). Default: every 15 minutes.
# Mind forecast.solar rate limits (free tier: 12 calls/hour/IP).
SF_CRON=0 */15 * * * *

# Metrics HTTP server
SF_METRICS_PORT=9090
SF_METRICS_BIND=0.0.0.0

# Log level: fatal|error|warn|info|debug|trace|silent
SF_LOG_LEVEL=info
